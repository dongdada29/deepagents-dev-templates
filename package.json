{
  "name": "deepagents-app-workspace",
  "version": "0.2.10",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "build": "pnpm --filter deepagents-app-ts build",
    "test": "pnpm --filter deepagents-app-ts test",
    "dev": "pnpm --filter deepagents-app-ts dev",
    "typecheck": "pnpm --filter deepagents-app-ts typecheck",
    "graph": "pnpm --filter deepagents-app-ts graph",
    "inspect": "pnpm --filter inspector inspect --"
  },
  "description": "DeepAgents development templates — monorepo for agent template and dev-agent config",
  "license": "MIT"
}
