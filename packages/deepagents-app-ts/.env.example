# ===========================================
# DeepAgents Dev Templates - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Model Provider API Keys ---
# Configure at least one model credential for the agent to call an LLM.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
OPENAI_API_KEY=

# --- Model Configuration ---
# Real deployments often set the concrete model and proxy/base URL here.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=

# --- Platform Configuration ---
# Nuwax platform API endpoint
PLATFORM_API_BASE_URL=https://api.nuwax.com
# Platform authentication token
PLATFORM_API_TOKEN=
# Agent and space identifiers
PLATFORM_AGENT_ID=
PLATFORM_SPACE_ID=

# --- ACP Server Configuration ---
# Agent name displayed in ACP clients
ACP_AGENT_NAME=my-scenario-agent
# Agent description
ACP_AGENT_DESCRIPTION=AI agent for [specific scenario]
# Enable debug mode (true/false)
ACP_DEBUG=false
# Workspace root directory (defaults to cwd)
# ACP_WORKSPACE_ROOT=

# --- MCP Configuration ---
# Path to additional MCP config file
# MCP_CONFIG_PATH=./config/mcp.custom.json

# --- ACP Startup Session Configuration ---
# Optional JSON supplied by nuwaclaw/platform at process launch.
# ACP_SESSION_CONFIG_JSON={"model":"claude-sonnet-4-6","agentId":"...","spaceId":"...","systemPrompt":"..."}

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- MinIO / S3 Distribution ---
# Local dev defaults; CI overrides via GitHub Actions secrets.
# DO NOT commit real credentials — only put them in .env (gitignored) or CI secrets.
# Production bucket: https://s3.nuwax.com:9443 / nuwax-packages
NUWAX_S3_ENDPOINT=
NUWAX_S3_REGION=us-east-1
NUWAX_S3_BUCKET=
NUWAX_S3_ACCESS_KEY_ID=
NUWAX_S3_SECRET_ACCESS_KEY=
# Set to 1 if the MinIO endpoint uses a self-signed certificate.
NUWAX_S3_NO_VERIFY_SSL=0
