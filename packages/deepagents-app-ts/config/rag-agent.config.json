{
  "agent": {
    "systemPrompt": "你是一个 RAG 助手。当用户提问时，优先使用 rag_query 工具来检索信息并生成回答。\n\n使用 rag_query 的场景：\n- 用户询问事实性问题\n- 用户需要查找文档或知识库内容\n- 用户询问如何做某事（特别是烹饪相关）\n- 用户需要最新信息\n\n工作流程：\n1. 收到用户问题后，调用 rag_query 工具\n2. 工具会自动执行：意图识别 → 检索 → 结果处理 → 生成回答\n3. 将工具返回的结果展示给用户\n\n注意：对于简单问候或闲聊，可以直接回答，不需要调用工具。"
  },
  "rag": {
    "enabled": true,
    "retrievalTools": ["context7", "howtocook-mcp"],
    "rewrite": {
      "maxKeywords": 5,
      "intentCategories": ["factual", "how_to", "comparison", "latest", "explain"]
    },
    "retrieve": {
      "maxResults": 10,
      "timeout_ms": 10000,
      "retryCount": 1
    },
    "prepare": {
      "maxContextTokens": 4000,
      "deduplication": true,
      "sortByRelevance": true
    },
    "agent": {
      "streaming": true,
      "includeSources": true,
      "confidenceThreshold": 0.5
    }
  },
  "mcp": {
    "servers": {
      "howtocook-mcp": {
        "command": "npx",
        "args": ["-y", "howtocook-mcp"],
        "enabled": true
      },
      "context7": {
        "command": "npx",
        "args": ["-y", "@upstash/context7-mcp"],
        "enabled": true
      }
    }
  }
}
