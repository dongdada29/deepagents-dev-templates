{
  "$schema": "./config-schema.json",
  "agent": {
    "name": "deepagents-app-ts",
    "description": "AI agent for [specific scenario]",
    "version": "0.4.2",
    "outputStyle": "concise"
  },
  "model": {
    "provider": "openai",
    "name": "mimo-v2.5-pro",
    "baseUrl": "https://token-plan-cn.xiaomimimo.com/v1",
    "settings": {
      "temperature": 0,
      "maxTokens": 16384
    }
  },
  "mcp": {
    "configPath": "./config/mcp.default.json",
    "mergeStrategy": "session-wins"
  },
  "permissions": {
    "mode": "yolo",
    "allowedPaths": ["src/app/", "prompts/", "skills/", "config/"],
    "deniedPaths": ["src/runtime/", "src/surfaces/"]
  }
}
