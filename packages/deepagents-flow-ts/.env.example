# 模型凭证 —— 与 deepagents-app-ts 一致。
# ACP 模式下通常由 IDE host(Zed/JetBrains) 注入；本地 CLI 测试时在这里配。
# 注：examples/ 与 dev-agent 真调大模型、无 demo fallback，必须配下面之一才能跑 LLM 节点。

# ── 模型（env-builtin 能力层）──────────────────────────
# 默认 provider=anthropic（见 config/flow-agent.config.json）
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=
# 自托管 / 代理端点时设置（指向你的网关）
ANTHROPIC_BASE_URL=

# 若改用 OpenAI 兼容端点（如 mimo）：把 config 的 model.provider 设为 "openai"、
# model.baseUrl 设为端点地址，并在此提供 key：
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ── nuwax 平台（acp-dynamic 能力层）────────────────────
# 配置后启用 platform_api 工具 + 平台绑定的 MCP 组件下发（见 capability-sources.json）
PLATFORM_AGENT_ID=
PLATFORM_SPACE_ID=
PLATFORM_API_TOKEN=

# ── MCP / 运行时 ────────────────────────────────────────
# 设为 disabled 可关闭默认 MCP（如不想拉起 context7）
# DEEPAGENTS_DEFAULT_MCP=disabled
# MCP 工具调用超时（毫秒）
# MCP_TOOL_TIMEOUT_MS=30000

# ── 日志 ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=
